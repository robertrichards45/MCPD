# =============================================================================
# MCPD Portal — Environment Variable Reference
# Copy to .env and fill in values for your deployment.
# NEVER commit your actual .env to version control.
# =============================================================================

# --- Core Security (REQUIRED for production) ---------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me

# "prod" enables secure cookies, HSTS, and HTTPS enforcement
APP_ENV=dev

# --- Database ----------------------------------------------------------------
DATABASE_URL=sqlite:///data/app.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@host:5432/mcpd

UPLOAD_ROOT=./data/uploads

# --- Admin Bootstrap (first-run only, blank after setup) ---------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- SMTP (packet email delivery) -------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1

# --- Application Domain ------------------------------------------------------
APP_DOMAIN=mclbpd.com
PREFERRED_URL_SCHEME=https

# --- HTTPS / Proxy -----------------------------------------------------------
FORCE_HTTPS=0
HSTS_ENABLED=0
HSTS_MAX_AGE=31536000
TRUST_PROXY=0
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SAMESITE=Lax

# --- OpenAI (optional — AI narrative assist; degrades gracefully if blank) --
OPENAI_API_KEY=

# --- CAC Authentication (optional) ------------------------------------------
CAC_AUTH_ENABLED=0
CAC_AUTO_REGISTER=0
CAC_DEBUG_ENABLED=0
CAC_USERNAME_HEADER=X-Authenticated-User
CAC_NAME_HEADER=X-Authenticated-Name
CAC_USERNAME_HEADERS=X-Authenticated-User,Cf-Access-Authenticated-User-Email,Cf-Access-Email
CAC_NAME_HEADERS=X-Authenticated-Name,Cf-Access-Authenticated-User-Name,Cf-Access-Name

# --- Feature Flags -----------------------------------------------------------
PUBLIC_SELF_REGISTER_ENABLED=1
LEGAL_AI_EXPANSION_ENABLED=1
ORDERS_AI_ASSIST_ENABLED=1
LEGAL_QUERY_LOG_ENABLED=1

# --- Misc --------------------------------------------------------------------
CLEO_URL=
GOOGLE_SITE_VERIFICATION=
