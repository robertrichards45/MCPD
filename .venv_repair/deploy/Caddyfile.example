# Example production reverse proxy for MCPD Portal with client-certificate auth.
# Caddy will obtain and renew the public TLS certificate automatically.
# Only the CAC issuer chain must be provided manually.
{
    # This host cannot bind :80 reliably, so keep the HTTPS listener on :443 only.
    # ACME can still validate over TLS-ALPN on 443.
    auto_https disable_redirects
}

mclbpd.com {
    encode zstd gzip

    tls {
        issuer acme {
            disable_http_challenge
        }

        client_auth {
            mode require_and_verify
            trust_pool file C:\certs\cac-chain.pem
        }
    }

    reverse_proxy 127.0.0.1:5055 {
        # Strip any spoofed headers from the client request first.
        header_up -X-Authenticated-User
        header_up -X-Authenticated-Name

        # Pass the verified client cert subject into the Flask app.
        # The app extracts the CN portion for username matching.
        header_up X-Authenticated-User {tls_client_subject}
        header_up X-Authenticated-Name {tls_client_subject}

        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
    }
}
